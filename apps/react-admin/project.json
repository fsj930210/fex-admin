{
  "name": "react-admin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/react-admin/src",
  "projectType": "application",
  "targets": {
    "dev": { "command": "vite --host 127.0.0.1 --port 4001 --strictPort", "options": { "cwd": "apps/react-admin" } },
    "build": {
      "command": "vite build",
      "options": { "cwd": "apps/react-admin" },
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": { "command": "tsc --noEmit -p apps/react-admin/tsconfig.json" },
    "lint": {
      "command": "oxlint apps/react-admin/src apps/react-admin/vite.config.ts"
    }
  }
}

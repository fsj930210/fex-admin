{
  "name": "docs",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/docs/src",
  "projectType": "application",
  "targets": {
    "dev": { "command": "vite", "options": { "cwd": "apps/docs" } },
    "build": {
      "command": "vite build",
      "options": { "cwd": "apps/docs" },
      "outputs": ["{projectRoot}/dist"]
    },
    "typecheck": { "command": "tsc --noEmit -p apps/docs/tsconfig.json" },
    "lint": { "command": "oxlint apps/docs/src apps/docs/vite.config.ts" }
  }
}
